
QMainWindow {
    background-color: #1e1e1e;
}
QPlainTextEdit {
    color: #dddddd;
    background-color: #1e1e1e;
    border: none;
    font-family: Consolas, monospace;
    font-size: 15pt;
}
QToolBar {
    background: #252526;
    spacing: 8px;
    padding: 4px;
}
QToolButton {
    color: #e9a5a5;
    padding: 6px 10px;
    background: #2d2d2d;
    border-radius: 6px;
}
QToolButton:hover {
    background: #3a3a3a;
}

/* Menu bar and menus */
QMenuBar {
    background-color: #252526; /* match toolbar */
    color: #cccccc;
}
QMenuBar::item {
    background: transparent;
    padding: 6px 10px;
    margin: 0 2px;
}
QMenuBar::item:selected {
    background: #3a3a3a;
    color: #ffffff;
}

QMenu {
    background-color: #2d2d2d;
    color: #e5e5e5;
    border: 1px solid #3a3a3a;
}
QMenu::item:selected {
    background-color: #3a3a3a;
    color: #ffffff;
}

/* Dock Widget styling */
QDockWidget {
    color: #dddddd;
    background-color: #252526;
    titlebar-close-icon: url(icons/close.svg);
}

QDockWidget::title {
    color: #dddddd;
    background-color: #252526;
    border-bottom: 1px solid #3a3a3a;
    padding: 6px;
    text-align: left;
}

QDockWidget::close-button, QDockWidget::float-button {
    background-color: transparent;
    padding: 4px;
    icon-size: 32px; /* Doubled from default ~16px */
    width: 40px;
    height: 40px;
    border-radius: 4px;
}

QDockWidget::close-button:hover, QDockWidget::float-button:hover {
    background-color: #3e3e3e;
}

/* Project explorer */
#projectExplorer {
    background-color: #252526;
    color: #dddddd;
}
#projectExplorerName {
    color: #f0f0f0;
    font-weight: 600;
    font-size: 10.5pt;
}
#projectExplorerPath {
    color: #999999;
    font-size: 8.25pt;
}
#projectFileTree {
    color: #dddddd;
    background-color: #252526;
    border: none;
    outline: none;
}
#projectFileTree::item {
    padding: 3px 2px;
}
#projectFileTree::item:hover {
    background-color: #2a2d2e;
}
#projectFileTree::item:selected {
    background-color: #37373d;
    color: #ffffff;
}

/* ScrollBar styling */
QScrollBar:vertical {
    border: none;
    background: #2d2d2d;
    width: 12px;
    margin: 0px 0px 0px 0px;
}
QScrollBar::handle:vertical {
    background: #cccccc;
    min-height: 20px;
    border-radius: 6px;
    margin: 2px;
}
QScrollBar::handle:vertical:hover {
    background: #e0e0e0;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    border: none;
    background: #2d2d2d;
    height: 12px;
    margin: 0px 0px 0px 0px;
}
QScrollBar::handle:horizontal {
    background: #cccccc;
    min-width: 20px;
    border-radius: 6px;
    margin: 2px;
}
QScrollBar::handle:horizontal:hover {
    background: #e0e0e0;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
}
QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}

/* Chat Panel Styling */
#chatPanel {
    background-color: transparent;
    color: #eeeeee;
}

#chatContainer {
    background-color: #2b2b2b;
}

#chatHeader {
    background-color: transparent;
}

#chatHeaderText {
    font-size: 13.5pt;
    font-weight: bold;
    color: #81c1d9;
}

#chatStatus {
    color: #b8c1c0;
    font-size: 8.25pt;
    padding: 0 4px;
}

#chatConversationArea,
#chatEmptyState,
#chatComposerHost {
    background-color: transparent;
    border: none;
}

#chatDisplay,
#chatTranscriptContent,
#chatDisplay > QWidget > QWidget {
    background-color: #2b2b2b;
    border: none;
}

#chatEmptyTitle {
    color: #eeeeee;
    font-size: 16pt;
    font-weight: bold;
}

#chatEmptyHint {
    color: #b8c1c0;
    font-size: 9.5pt;
}

#chatComposer {
    background-color: #333333;
    border: 1px solid #454545;
    border-radius: 14px;
}

#chatComposer:focus-within {
    border-color: #81c1d9;
}

#chatInput {
    background-color: transparent;
    color: #eeeeee;
    border: none;
    padding: 3px 2px;
    selection-background-color: #527b8a;
}

#newChatButton {
    background-color: transparent;
    color: #b8c1c0;
    border: none;
    border-radius: 7px;
    padding: 6px 9px;
    font-size: 9pt;
}

#newChatButton:hover {
    background-color: #3a3a3a;
    color: #eeeeee;
}

#newChatButton:disabled {
    color: #666666;
}

#chatCloseButton {
    background-color: transparent;
    color: #b8c1c0;
    border: none;
    border-radius: 7px;
    padding: 0;
    font-size: 15pt;
}

#chatCloseButton:hover {
    background-color: #3a3a3a;
    color: #eeeeee;
}

#attachButton {
    background-color: transparent;
    color: #81c1d9;
    border: none;
    border-radius: 7px;
    padding: 0;
    font-size: 16pt;
    font-weight: bold;
}

#attachButton:hover,
#sendButton:hover {
    background-color: #3f3f3f;
}

#attachButton::menu-indicator {
    subcontrol-origin: padding;
    subcontrol-position: bottom right;
    width: 7px;
    height: 7px;
}

#sendButton {
    background-color: transparent;
    border: none;
    border-radius: 7px;
    padding: 0px;
    margin: 0px;
}

#agentSelector,
#modelSelector {
    background-color: transparent;
    color: #b8c1c0;
    border: none;
    border-radius: 7px;
    padding: 5px 23px 5px 8px;
    min-height: 20px;
}

#agentSelector:hover,
#modelSelector:hover,
#agentSelector:on,
#modelSelector:on {
    background-color: #3f3f3f;
    color: #eeeeee;
}

#agentSelector::drop-down,
#modelSelector::drop-down {
    border: none;
    width: 20px;
}

#agentSelector QAbstractItemView,
#modelSelector QAbstractItemView {
    background-color: #2d2d2d;
    color: #eeeeee;
    selection-background-color: #444444;
    border: 1px solid #444444;
}

#chatMessage {
    background-color: #303030;
    border: none;
    border-radius: 10px;
}

#chatMessage[role="user"] {
    background-color: #353232;
}

#chatMessage[role="assistant"] {
    background-color: #303334;
}

#chatMessage[role="system"],
#chatMessage[role="thinking"] {
    background-color: transparent;
}

#messageRole {
    color: #b8c1c0;
    font-size: 8.5pt;
    font-weight: bold;
}

#messageRole[role="user"] {
    color: #e9a5a5;
}

#messageRole[role="assistant"] {
    color: #81c1d9;
}

#messageRole[role="thinking"] {
    color: #aea2db;
}

#messageText {
    color: #eeeeee;
    font-size: 10pt;
}

#chatMessage[role="system"] #messageText,
#chatMessage[role="thinking"] #messageText {
    color: #b8c1c0;
}

#messageCopyButton {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 0;
}

#messageCopyButton:hover {
    background-color: #454545;
}

#chatContainer QScrollArea {
    background-color: transparent;
}

/* RAG Management Dialog */
#ragDialog {
    background-color: #1e1e1e;
}

#ragHeader {
    font-size: 16px; 
    font-weight: bold; 
    color: #dddddd;
}

#ragDescription {
    color: #aaaaaa;
}

#ragFileList {
    background-color: #2d2d2d;
    color: #dddddd;
    border: 1px solid #444444;
    border-radius: 4px;
    padding: 5px;
}

#ragFileList::item {
    padding: 8px;
    border-bottom: 1px solid #3d3d3d;
}

#ragFileList::item:selected {
    background-color: #3e3e3e;
}

#ragBtnRemove {
    background-color: #d9534f;
    color: white;
    border-radius: 4px;
    padding: 8px 15px;
    font-weight: bold;
}

#ragBtnRemove:hover {
    background-color: #c9302c;
}

#ragBtnRemove:disabled {
    background-color: #555555;
    color: #888888;
}

#ragBtnClearAll {
    background-color: #555555;
    color: #dddddd;
    border-radius: 4px;
    padding: 8px 15px;
}

#ragBtnClearAll:hover {
    background-color: #666666;
}

#ragBtnClose {
    background-color: transparent;
    color: #dddddd;
    border: 1px solid #444444;
    border-radius: 4px;
    padding: 8px 15px;
}

#ragBtnClose:hover {
    background-color: #3a3a3a;
}

/* LLM Setup Dialog Styling */
#llmSetupDialog {
    background-color: #1e1e1e;
}

#llmSetupHeader {
    padding: 20px;
    border-bottom: 1px solid #e9a5a5;
}

#llmSetupTitle {
    font-size: 16px;
    font-weight: bold;
    color: #dddddd;
}

#llmSetupSubtitle {
    font-size: 12px;
    color: #888888;
}

#llmSetupBody {
    padding: 10px 20px;
    background-color: #1e1e1e;
}

.providerSection {
    border-bottom: 1px solid #e9a5a5;
    padding: 15px 0;
}

.providerLabel {
    font-size: 13px;
    font-weight: bold;
    color: #e9a5a5;
    text-transform: uppercase;
}

.providerBadge {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 10px;
}

.badgeLocal { background-color: #1e1e1e; color: #65c0e0; }
.badgeCloud { background-color: #1e1e1e; color: #65c0e0; }

.apiKeyRow {
    margin-top: 10px;
}

.apiKeyLabel {
    font-size: 13px;
    font-weight: bold;
    color: #dddddd;
}

.apiKeyInput {
    background-color: #1e1e1e;
    color: #dddddd;
    border: 1px solid #dddddd;
    border-radius: 4px;
    padding: 5px 10px;
    font-family: Consolas, monospace;
}

.modelRow {
    margin-top: 5px;
}

.modelInput {
    background-color: #1e1e1e;
    color: #dddddd;
    border: 1px solid #dddddd;
    border-radius: 4px;
    padding: 5px 10px;
}

.modelInputValid { border-color: #dddddd; }
.modelInputInvalid { border-color: #a33c3c; }

.removeBtn {
    background-color: transparent;
    color: #888888;
    border: 1px solid #333333;
    border-radius: 4px;
    padding: 4px;
}

.removeBtn:hover {
    color: #ff5555;
    border-color: #ff5555;
    background-color: #2d1a1a;
}

.addBtn {
    background-color: transparent;
    color: #dddddd;
    border: 1px dashed #dddddd;
    border-radius: 4px;
    padding: 6px 12px;
    font-size: 12px;
    margin-top: 8px;
}

.addBtn:hover {
    color: #1e1e1e;
    border-color: #e9a5a5;
    background-color: #e9a5a5;
}

.validationMsg {
    font-size: 11px;
    padding: 6px 10px;
    border-radius: 4px;
    margin-top: 4px;
}

.validationWarn { background-color: #a33c3c; color: #dddddd; }
.validationOk { background-color: #1e1e1e; color: #65c0e0; }    

.cloudNote {
    font-size: 11px;
    color: #888888;
    font-style: italic;
    margin-top: 4px;
}

#llmSetupFooter {
    padding: 20px;
    background-color: #1e1e1e;
    color: #dddddd;
    border-top: 1px solid #e9a5a5;
}

.defaultLabel {
    font-size: 13px;
    font-weight: bold;
    color: #dddddd;
}

.defaultSelect {
    background-color: #1e1e1e;
    color: #dddddd;
    border: 1px solid #e9a5a5;
    border-radius: 4px;
    padding: 5px;
}

.defaultSelect QAbstractItemView {
    background-color: #2d2d2d;
    color: #eeeeee;
    selection-background-color: #444444;
    border: 1px solid #444444;
}

.apiStatus {
    font-size: 11px;
    margin-left: 8px;
}

.apiOk { color: #a3d977; }
.apiMissing { color: #d9a377; }


/* LLM Settings Dialog Styling */
#llmSettingsDialog {
    background-color: #1e1e1e;
}

#settingsPanel {
    background-color: #1e1e1e;
    border: 1px solid #333333;
    border-radius: 10px;
}

#settingsHeader {
    padding: 15px 20px;
    border-bottom: 1px solid #333333;
}

#settingsTitle {
    font-size: 15px;
    font-weight: bold;
    color: #dddddd;
}

#modelPill {
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 6px;
    background-color: #dddddd;
    border: 1px solid #333333;
    color: #1e1e1e;
    font-family: Consolas, monospace;
}

#settingsBody {
    padding: 15px 20px;
}

.presetBtn {
    height: 32px;
    border-radius: 6px;
    font-size: 12px;
    border: 1px solid #333333;
    background-color: transparent;
    color: #aaaaaa;
}

.presetBtn:hover {
    background-color: #2d2d2d;
    color: #dddddd;
}

.presetBtn[active="true"] {
    background-color: #dddddd;
    color: #1e1e1e;
    border: 1px solid #dddddd;
}

.sectionDivider {
    font-size: 11px;
    font-weight: bold;
    color: #e9a5a5;
    text-transform: uppercase;
    margin-top: 20px;
    margin-bottom: 10px;
    border-bottom: 1px solid #333333;
    padding-bottom: 5px;
}

.paramLabel {
    font-size: 13px;
    color: #dddddd;
    font-weight: bold;
}

.paramDesc {
    font-size: 11px;
    color: #888888;
}

.paramValue {
    font-size: 13px;
    font-weight: bold;
    color: #dddddd;
    font-family: Consolas, monospace;
}

.rangeLabel {
    font-size: 11px;
    color: #888888;
}

#seedInput {
    background-color: #2d2d2d;
    color: #dddddd;
    border: 1px solid #333333;
    border-radius: 6px;
    padding: 5px 10px;
    font-family: Consolas, monospace;
}

#seedInput:focus {
    border-color: #444444;
}

#seedInput:disabled {
    color: #555555;
}

/* Toggle Switch Styling */
#seedToggle {
    background-color: #2d2d2d;
    color: #dddddd;
    border: 1px solid #333333;
    border-radius: 9px;
    width: 32px;
    height: 18px;
}

#seedToggle[checked="true"] {
    background-color: #dddddd;
}

#settingsFooter {
    padding: 15px 20px;
    border-top: 1px solid #333333;
    background-color: #2d2d2d;
}

#resetToDefaultsBtn {
    font-size: 12px;
    color: #888888;
    background: none;
    border: none;
}

#resetToDefaultsBtn:hover {
    color: #65c0e0;
}

.footerBtn {
    height: 30px;
    padding: 0 14px;
    border: none;
    border-radius: 6px;
    font-size: 13px;
    background-color: transparent;
    color: #dddddd;
}

.footerBtn:hover {
    color: #65c0e0;
}

/* Styles for "Save" and "Apply" buttons in both settings panel and LLM setup panel */

.btnPrimary {
    background-color: #dddddd;
    color: #1e1e1e;
    font-weight: bold;
    border: 1px solid #dddddd;
    padding: 4px 14px;
    border-radius: 4px;
}

.btnPrimary:hover {
    background-color: #65c0e0;
}
